    <script type="module">
      import { initializeApp, getApps } from "https://www.gstatic.com/firebasejs/9.22.0/firebase-app.js";
      import { getDatabase, ref, set, get, update, onValue, runTransaction } from "https://www.gstatic.com/firebasejs/9.22.0/firebase-database.js";

      // Reuse the same Firebase app as the main system (nj_main_sys)
      const njApp = getApps().find(a=>a.name==='nj_main_sys') || initializeApp({
        apiKey:"AIzaSyDW9xdFdxFSjAm15f-l107fQpmZbs6_vEw",
        authDomain:"trolling-e3ed8.firebaseapp.com",
        databaseURL:"https://trolling-e3ed8-default-rtdb.firebaseio.com",
        projectId:"trolling-e3ed8",
        storageBucket:"trolling-e3ed8.appspot.com",
        messagingSenderId:"299260439019",
        appId:"1:299260439019:web:9dedc986334a871e1d51ae"
      }, 'nj_main_sys');
      const njDb = getDatabase(njApp);

      // ── Helpers ──
      const fmtTime = s => { const h=Math.floor(s/3600),m=Math.floor((s%3600)/60); return h>0?`${h}h ${m}m`:`${m}m`; };
      const todayKey = () => new Date().toISOString().slice(0,10);
      const weekKey  = () => { const d=new Date(),j=new Date(d.getFullYear(),0,1),w=Math.ceil(((d-j)/864e5+j.getDay()+1)/7); return `${d.getFullYear()}-W${String(w).padStart(2,'0')}`; };
      function showToast(msg, ms=3000) {
        const t=document.getElementById('nj-toast');
        if(!t)return; t.textContent=msg; t.style.display='block';
        clearTimeout(window._njToast); window._njToast=setTimeout(()=>t.style.display='none',ms);
      }

      // ── Redirect Shield ──
      // Block any external navigation / popup attempts from within iframes
      (function(){
        // 1. Override window.open so game iframes can't open external tabs
        const _origOpen = window.open.bind(window);
        window.open = function(url, target, features) {
          if(!url) return _origOpen(url, target, features);
          try {
            const u = new URL(url, location.href);
            // Allow same-origin opens (e.g. chat popup)
            if(u.origin === location.origin) return _origOpen(url, target, features);
          } catch(e){}
          showToast('🛡️ External link blocked');
          return null;
        };

        // 2. Block top-level navigation away from the page (belt-and-suspenders)
        window.addEventListener('beforeunload', function(e) {
          // Only fire if a game is currently open (iframe is visible)
          const frame = document.querySelector('iframe[sandbox]');
          if(frame && frame.offsetParent !== null) {
            e.preventDefault();
            e.returnValue = '';
          }
        });

        // 3. Catch postMessage navigation attempts from game iframes
        window.addEventListener('message', function(e) {
          const d = e.data;
          if(!d) return;
          const str = typeof d === 'string' ? d : JSON.stringify(d);
          // Block common redirect patterns games send via postMessage
          if(/navigate|redirect|location|href|open\s*url/i.test(str) && /https?:\/\//i.test(str)) {
            showToast('🛡️ Redirect blocked');
          }
        });
      })();

      // ── State ──
      let njUser=null, njCoins=0, njStreak=0, njPtTotal=0, njPtWeekly=0;
      let njEquipped={}, njOwned={}, njShopTab='color', njPendingBox=null;
      // ── Boost helpers (localStorage-backed timers) ──
      const BOOST_DURATION={double_coins:30*60000, xp_boost:15*60000};
      function isBoostActive(val){ const e=parseInt(localStorage.getItem('nj_boost_'+val)||'0'); return Date.now()<e; }
      function boostRemaining(val){ const r=parseInt(localStorage.getItem('nj_boost_'+val)||'0')-Date.now(); if(r<=0)return null; const m=Math.floor(r/60000),s=Math.floor((r%60000)/1000); return m>0?m+'m '+s+'s':s+'s'; }
      function activateBoost(val){ localStorage.setItem('nj_boost_'+val, (Date.now()+(BOOST_DURATION[val]||900000)).toString()); }
      let njXp=0, njLevel=1, njXpWeekly=0, _jomgShown=false;
      let _ptActive=false, _ptActiveGame=null, _ptActivityTimer=null;
      let _ptGamesSet=new Set();

      // ── Shop Items ──
      const SHOP = {
        'col-purple':  {name:'Purple Glow',  type:'chatColor',price:150,icon:'🟣',desc:'Purple chat text',     val:'#a855f7'},
        'col-gold':    {name:'Gold Text',     type:'chatColor',price:200,icon:'🟡',desc:'Gold chat text',       val:'#f59e0b'},
        'col-red':     {name:'Red Hot',       type:'chatColor',price:100,icon:'🔴',desc:'Red chat text',        val:'#ef4444'},
        'col-cyan':    {name:'Cyan Wave',     type:'chatColor',price:100,icon:'🔵',desc:'Cyan chat text',       val:'#06b6d4'},
        'col-green':   {name:'Neon Green',    type:'chatColor',price:100,icon:'🟢',desc:'Green chat text',      val:'#22c55e'},
        'col-pink':    {name:'Hot Pink',      type:'chatColor',price:175,icon:'🩷',desc:'Pink chat text',       val:'#ec4899'},
        'col-rainbow': {name:'Rainbow',       type:'chatColor',price:500,icon:'🌈',desc:'Animated rainbow text',val:'rainbow'},
        'bdg-star':    {name:'⭐ Star',        type:'badge',    price:50, icon:'⭐',desc:'Star badge by name',   val:'⭐'},
        'bdg-fire':    {name:'🔥 Fire',        type:'badge',    price:100,icon:'🔥',desc:'Fire badge',           val:'🔥'},
        'bdg-crown':   {name:'👑 Crown',       type:'badge',    price:300,icon:'👑',desc:'Crown badge',          val:'👑'},
        'bdg-diamond': {name:'💎 Diamond',     type:'badge',    price:200,icon:'💎',desc:'Diamond badge',        val:'💎'},
        'bdg-gamer':   {name:'🎮 Gamer',       type:'badge',    price:50, icon:'🎮',desc:'Gamer badge',          val:'🎮'},
        'bdg-skull':   {name:'💀 Skull',       type:'badge',    price:150,icon:'💀',desc:'Skull badge',          val:'💀'},
        'bdg-rocket':  {name:'🚀 Rocket',      type:'badge',    price:125,icon:'🚀',desc:'Rocket badge',         val:'🚀'},
        'ttl-grinder': {name:'Grinder',        type:'title',    price:200,icon:'💪',desc:'"Grinder" title',      val:'Grinder'},
        'ttl-nolife':  {name:'No Life',        type:'title',    price:500,icon:'😴',desc:'"No Life" title',      val:'No Life'},
        'ttl-legend':  {name:'Legend',         type:'title',    price:400,icon:'🌟',desc:'"Legend" title',       val:'Legend'},
        'ttl-speed':   {name:'Speed Runner',   type:'title',    price:150,icon:'⚡',desc:'"Speed Runner" title', val:'Speed Runner'},
        'ttl-pro':     {name:'Pro Gamer',      type:'title',    price:250,icon:'🏆',desc:'"Pro Gamer" title',    val:'Pro Gamer'},
        'ttl-casual':  {name:'Casual',         type:'title',    price:75, icon:'🎯',desc:'"Casual" title',       val:'Casual'},
        'col-orange':  {name:'Orange Fire',    type:'chatColor',price:125,icon:'🟠',desc:'Orange chat text',      val:'#f97316'},
        'col-white':   {name:'Pure White',     type:'chatColor',price:80, icon:'⬜',desc:'White chat text',       val:'#f8fafc'},
        'col-blue':    {name:'Ocean Blue',     type:'chatColor',price:100,icon:'🔷',desc:'Blue chat text',        val:'#3b82f6'},
        'col-teal':    {name:'Teal',           type:'chatColor',price:110,icon:'🩵',desc:'Teal chat text',        val:'#14b8a6'},
        'col-lime':    {name:'Lime',           type:'chatColor',price:90, icon:'🟩',desc:'Lime chat text',        val:'#84cc16'},
        'col-magenta': {name:'Magenta',        type:'chatColor',price:140,icon:'🟣',desc:'Magenta chat text',     val:'#d946ef'},
        'bdg-lightning':{name:'⚡ Lightning',  type:'badge',    price:75, icon:'⚡',desc:'Lightning badge',       val:'⚡'},
        'bdg-rainbow': {name:'🌈 Rainbow',     type:'badge',    price:200,icon:'🌈',desc:'Rainbow badge',         val:'🌈'},
        'bdg-alien':   {name:'👽 Alien',       type:'badge',    price:80, icon:'👽',desc:'Alien badge',           val:'👽'},
        'bdg-robot':   {name:'🤖 Robot',       type:'badge',    price:90, icon:'🤖',desc:'Robot badge',           val:'🤖'},
        'bdg-cat':     {name:'🐱 Cat',         type:'badge',    price:60, icon:'🐱',desc:'Cat badge',             val:'🐱'},
        'bdg-snake':   {name:'🐍 Snake',       type:'badge',    price:70, icon:'🐍',desc:'Snake badge',           val:'🐍'},
        'bdg-brain':   {name:'🧠 Brain',       type:'badge',    price:100,icon:'🧠',desc:'Brain badge',           val:'🧠'},
        'bdg-clown':   {name:'🤡 Clown',       type:'badge',    price:50, icon:'🤡',desc:'Clown badge',           val:'🤡'},
        'ttl-goat':    {name:'G.O.A.T',        type:'title',    price:600,icon:'🐐',desc:'"G.O.A.T" title',       val:'G.O.A.T'},
        'ttl-veteran': {name:'Veteran',        type:'title',    price:300,icon:'🎖️',desc:'"Veteran" title',       val:'Veteran'},
        'ttl-newbie':  {name:'Newbie',         type:'title',    price:25, icon:'🐣',desc:'"Newbie" title',         val:'Newbie'},
        'ttl-mvp':     {name:'MVP',            type:'title',    price:350,icon:'🏅',desc:'"MVP" title',            val:'MVP'},
        'ttl-boss':    {name:'Boss',           type:'title',    price:450,icon:'😎',desc:'"Boss" title',           val:'Boss'},
        'ttl-wizard':  {name:'Wizard',         type:'title',    price:225,icon:'🧙',desc:'"Wizard" title',         val:'Wizard'},
        'ttl-hacker':  {name:'Hacker',         type:'title',    price:300,icon:'💻',desc:'"Hacker" title',         val:'Hacker'},
        'ttl-champion':{name:'Champion',       type:'title',    price:400,icon:'🏆',desc:'"Champion" title',       val:'Champion'},
        'box-common':  {name:'Common Box',     type:'lootbox',  price:30, icon:'📦',desc:'Random rewards',       val:'common'},
        'box-rare':    {name:'Rare Box',       type:'lootbox',  price:100,icon:'💜',desc:'Better rewards',        val:'rare'},
        'box-epic':    {name:'Epic Box',       type:'lootbox',  price:250,icon:'🌟',desc:'Guaranteed rare+',      val:'epic'},
        'box-legendary':{name:'Legendary Box', type:'lootbox',  price:750,icon:'🔱',desc:'Top-tier rewards!',     val:'legendary'},
        'ad-double-coins': {name:'Double Coins',  type:'boost', price:50, icon:'⚡',desc:'2× coins for 30 minutes! Activate for 50 🪙', val:'double_coins'},
        'ad-xp-boost':     {name:'XP Boost',      type:'boost', price:25, icon:'🚀',desc:'2× XP for 15 minutes! Activate for 25 🪙', val:'xp_boost'},
      };

      // ── Daily Challenges (seeded by date) ──
      function getDailyChallenges() {
        const k=todayKey(), parts=k.split('-');
        let s=parts.reduce((a,v)=>a*100+parseInt(v),0);
        const rng=()=>{ s=(s*16807)%2147483647; return s/2147483647; };
        const types=[
          {type:'play_minutes', tgts:[5,10,15,20],   rwds:[10,15,20,25], lbl:t=>`Play for ${t} minutes`},
          {type:'play_games',   tgts:[2,3,5,7],      rwds:[10,15,20,30], lbl:t=>`Play ${t} different games`},
          {type:'chat_msgs',    tgts:[3,5,10,15],    rwds:[10,15,20,30], lbl:t=>`Send ${t} chat messages`},
          {type:'stay_active',  tgts:[10,15,20,30],  rwds:[10,15,20,30], lbl:t=>`Stay active ${t} minutes`},
        ];
        const used=new Set(), out=[];
        for(let i=0;i<3;i++){
          let ti; do{ti=Math.floor(rng()*types.length);}while(used.has(ti)&&used.size<types.length);
          used.add(ti); const t=types[ti], ri=Math.floor(rng()*t.tgts.length);
          out.push({type:t.type,target:t.tgts[ri],reward:t.rwds[ri],label:t.lbl(t.tgts[ri])});
        }
        return out;
      }

      // ── Coins ──
      async function awardCoins(amt, msg='') {
        if(!njUser||amt<=0)return;
        if((_njConfig.coinMult||1)>1)amt=Math.round(amt*(_njConfig.coinMult||1));
        if((_njConfig.rewardsEnabled===false))return;
        await runTransaction(ref(njDb,`njsgames/users/${njUser}/coins`),c=>(c||0)+amt);
        njCoins+=amt; updateHdrStats();
        if(msg) showToast(`${msg} +${amt} 🪙`);
      }

      // ── XP & Level system ──
      function xpForLevel(lvl){ return lvl * 100; }
      function getLevel(xp){ let l=1; while(xp>=xpForLevel(l))xp-=xpForLevel(l++); return l-1||1; }
      async function awardXp(amt, quiet=false){
        if(!njUser||amt<=0)return;
        if(isBoostActive('xp_boost'))amt=Math.round(amt*2);
        if((_njConfig.xpMult||1)>1)amt=Math.round(amt*(_njConfig.xpMult||1));
        const oldLvl=njLevel;
        const wk=weekKey();
        await runTransaction(ref(njDb,`njsgames/users/${njUser}/xp`),x=>(x||0)+amt);
        njXp+=amt; njXpWeekly+=amt;
        await update(ref(njDb,`njsgames/users/${njUser}/xpWeekly`),{[wk]:njXpWeekly,lastWeek:wk});
        set(ref(njDb,`njsgames/leaderboard/xp-weekly/${wk}/${njUser}`),njXpWeekly);
        let newLvl=1, rem=njXp;
        while(rem>=xpForLevel(newLvl)){rem-=xpForLevel(newLvl);newLvl++;}
        if(newLvl>oldLvl){ njLevel=newLvl; updateHdrStats(); showLevelUp(newLvl); }
        else { updateHdrStats(); }
        if(!quiet&&amt>=10)showToast(`+${amt} XP ✨`);
      }
      function showLevelUp(lvl){
        const ov=document.getElementById('nj-levelup-overlay');
        if(!ov)return;
        document.getElementById('nj-levelup-num').textContent=lvl;
        ov.style.display='flex';
        setTimeout(()=>ov.style.display='none',3500);
      }

      // ── Streak ──
      function checkStreak(streakData) {
        const today=todayKey(), last=streakData.lastDate||'';
        if(last===today)return;
        const yest=new Date(Date.now()-864e5).toISOString().slice(0,10);
        const nw = last===yest ? (streakData.current||0)+1 : 1;
        const lng = Math.max(nw, streakData.longest||0);
        update(ref(njDb,`njsgames/users/${njUser}/streak`),{current:nw,lastDate:today,longest:lng});
        njStreak=nw; updateHdrStats();
        const bonuses={3:15,7:25,14:50,30:100};
        if(bonuses[nw]) awardCoins(bonuses[nw],`🔥 ${nw}-day streak bonus!`);
        else if(nw>1) awardCoins(5,`🔥 Day ${nw} streak`);
        else showToast('🎮 Welcome! Streak started!');
      }

      // ── Weekly reset check ──
      async function checkWeeklyReset(data) {
        const wk=weekKey(), lastWk=data.playtime?.lastWeek;
        if(lastWk&&lastWk!==wk){
          // Playtime leaderboard rewards
          const lb=await get(ref(njDb,`njsgames/leaderboard/weekly/${lastWk}`));
          if(lb.exists()){
            const entries=Object.entries(lb.val()).sort((a,b)=>b[1]-a[1]).slice(0,3);
            [100,75,50].forEach((coins,i)=>{ if(entries[i]) runTransaction(ref(njDb,`njsgames/users/${entries[i][0]}/coins`),c=>(c||0)+coins); });
          }
          // XP leaderboard rewards
          const xlb=await get(ref(njDb,`njsgames/leaderboard/xp-weekly/${lastWk}`));
          if(xlb.exists()){
            const xentries=Object.entries(xlb.val()).sort((a,b)=>b[1]-a[1]).slice(0,3);
            [75,50,25].forEach((coins,i)=>{ if(xentries[i]) runTransaction(ref(njDb,`njsgames/users/${xentries[i][0]}/coins`),c=>(c||0)+coins); });
          }
        }
        update(ref(njDb,`njsgames/users/${njUser}/playtime`),{lastWeek:wk});
      }

      // ── Load user ──
      async function loadUser(u) {
        njUser=u;
        const snap=await get(ref(njDb,`njsgames/users/${u}`));
        const d=snap.val()||{};
        njCoins=d.coins||0; njStreak=d.streak?.current||0;
        njPtTotal=d.playtime?.total||0; njPtWeekly=d.playtime?.weekly?.[weekKey()]||0;
        njXp=d.xp||0; njXpWeekly=d.xpWeekly?.[weekKey()]||0;
        let _rem=njXp; njLevel=1; while(_rem>=xpForLevel(njLevel)){_rem-=xpForLevel(njLevel);njLevel++;}
        njEquipped=d.equipped||{}; njOwned=d.items||{};
        updateHdrStats();
        checkStreak(d.streak||{});
        checkWeeklyReset(d);
        // Daily login bonus
        const dk=`nj_daily_${todayKey()}`;
        if(!localStorage.getItem(dk)){ localStorage.setItem(dk,'1'); awardCoins(10,'📅 Daily login'); awardXp(25,true); }
        // Real-time coin sync
        onValue(ref(njDb,`njsgames/users/${u}/coins`),s=>{ const v=s.val()||0; if(v!==njCoins){njCoins=v;updateHdrStats();} });
        onValue(ref(njDb,`njsgames/users/${u}/streak/current`),s=>{ const v=s.val()||0; if(v!==njStreak){njStreak=v;updateHdrStats();} });
      }

      // ── Playtime tracking ──
      function setupTracking() {
        const act=()=>{ _ptActive=true; clearTimeout(_ptActivityTimer); _ptActivityTimer=setTimeout(()=>_ptActive=false,60000); };
        ['mousemove','keydown','click','touchstart'].forEach(e=>document.addEventListener(e,act,{passive:true}));
        act();
        document.addEventListener('visibilitychange',()=>{ if(document.hidden)_ptActive=false; else act(); });
        // Watch for iframe src changes (game launched)
        let _lastSrc='';
        setInterval(()=>{
          const fr=document.querySelector('iframe[src]');
          if(fr&&fr.src&&fr.src!==_lastSrc){ _lastSrc=fr.src; _ptActiveGame=fr.src; _ptGamesSet.add(fr.src); }
        },1000);
        // Track game open/close for "Just One More Game"
        // Only fires after the user has actually played a game this session
        const _jomgGameDomains=['github.io','gitlab.io','twoplayergames','crazygames','rocket-soccer','htmlxm','ubg','unblokedgames','st.8games','smash-kartsonline','slope-game','jasongamesdev','tylerpalko','sciencemathlearning','eli-schwartz','nb-ga','fireboywatergirl','penaltyshooters','classroomjq','basketball-legends','poopclicker','ubg77'];
        function _isGameUrl(src){ return src&&_jomgGameDomains.some(d=>src.includes(d)); }
        let _jomgLastSrc='', _jomgTimer=null, _jomgEverPlayed=false, _jomgLastGameUrl='';
        setInterval(()=>{
          const fr=document.querySelector('iframe[src]');
          const curSrc=fr?fr.src:'';
          const isGame=_isGameUrl(curSrc);
          if(isGame){
            _jomgEverPlayed=true;
            _jomgLastGameUrl=curSrc;
            clearTimeout(_jomgTimer);
          }
          // Only show JOMG when: had a real game → now no game (or non-game iframe)
          if(_jomgEverPlayed&&_jomgLastSrc&&!isGame&&!curSrc&&!_jomgShown){
            clearTimeout(_jomgTimer);
            _jomgTimer=setTimeout(()=>{ showJomg(); },1200);
          }
          if(isGame)clearTimeout(_jomgTimer);
          _jomgLastSrc=isGame?curSrc:'';
        },500);
        function showJomg(){
          const ov=document.getElementById('nj-jomg-overlay');
          if(ov&&!_jomgShown){ _jomgShown=true; ov.style.display='flex'; }
        }
        window.njJomgPlay=function(){
          document.getElementById('nj-jomg-overlay').style.display='none';
          _jomgShown=false;
          awardXp(20,true);
          showToast('🎮 +20 XP bonus! Enjoy the next game!');
          // Re-launch last game in a fullscreen overlay
          if(!_jomgLastGameUrl)return;
          const ov=document.createElement('div');
          ov.id='nj-jomg-game-overlay';
          ov.style.cssText='position:fixed;inset:0;z-index:19999;background:#000;display:flex;flex-direction:column;';
          ov.innerHTML=`<div style="background:#0f0f1a;padding:8px 16px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;border-bottom:1px solid #2a2a4a;">
            <span style="color:#a78bfa;font-weight:700;font-size:14px">🎮 One More Game!</span>
            <button onclick="document.getElementById('nj-jomg-game-overlay').remove();_jomgShown=false;" style="background:none;border:none;color:#6b7280;cursor:pointer;font-size:22px;line-height:1;padding:4px">✕</button>
          </div>
          <iframe src="${_jomgLastGameUrl}" style="flex:1;border:none;width:100%;height:100%;" allowfullscreen sandbox="allow-scripts allow-same-origin allow-pointer-lock allow-forms allow-popups allow-presentation"></iframe>`;
          document.body.appendChild(ov);
        };
        window.njJomgClose=function(){
          document.getElementById('nj-jomg-overlay').style.display='none';
          setTimeout(()=>_jomgShown=false, 8000);
        };

        // Save playtime every 15s (requires active game)
        setInterval(async()=>{
          if(!document.hidden&&_ptActive&&_ptActiveGame&&njUser){
            const add=15, wk=weekKey(), td=todayKey();
            njPtTotal+=add; njPtWeekly+=add;
            await update(ref(njDb,`njsgames/users/${njUser}/playtime`),{total:njPtTotal,[`weekly/${wk}`]:njPtWeekly,lastWeek:wk});
            set(ref(njDb,`njsgames/leaderboard/weekly/${wk}/${njUser}`),njPtWeekly);
            // Update challenge progress
            updChallenge('play_minutes',Math.floor(njPtTotal/60));
            updChallenge('play_games',_ptGamesSet.size);
            awardXp(10,true); // 10 XP per 15s active gameplay
          }
        },15000);
        // Stay-active tracker — no game required, just be on the site
        let _stayActiveTodaySecs=0, _stayActiveDay=todayKey();
        setInterval(async()=>{
          if(!document.hidden&&_ptActive&&njUser){
            const td=todayKey();
            if(td!==_stayActiveDay){ _stayActiveTodaySecs=0; _stayActiveDay=td; }
            _stayActiveTodaySecs+=15;
            updChallenge('stay_active',Math.floor(_stayActiveTodaySecs/60));
          }
        },15000);
      }

      // ── Challenge progress ──
      async function updChallenge(type, newVal) {
        if(!njUser)return;
        const td=todayKey(), chs=getDailyChallenges();
        const base=`njsgames/challenges/progress/${td}/${njUser}`;
        for(let i=0;i<chs.length;i++){
          if(chs[i].type!==type)continue;
          const prev=(await get(ref(njDb,`${base}/c${i+1}`))).val()||0;
          if(newVal<=prev)continue;
          await set(ref(njDb,`${base}/c${i+1}`),newVal);
          if(prev<chs[i].target&&newVal>=chs[i].target){
            const claimed=(await get(ref(njDb,`${base}/claimed${i+1}`))).val();
            if(!claimed){ await set(ref(njDb,`${base}/claimed${i+1}`),true); awardCoins(chs[i].reward,`⚡ ${chs[i].label}`); checkAllDone(base,chs); }
          }
        }
      }
      async function checkAllDone(base,chs){
        const already=(await get(ref(njDb,`${base}/bonusClaimed`))).val(); if(already)return;
        for(let i=0;i<3;i++){ if(((await get(ref(njDb,`${base}/c${i+1}`))).val()||0)<chs[i].target)return; }
        await set(ref(njDb,`${base}/bonusClaimed`),true); awardCoins(25,'🎯 All challenges done! Bonus');
      }
      window.njTrackChat=async function(){
        if(!njUser)return;
        const k=`njsgames/challenges/progress/${todayKey()}/${njUser}/chat_total`;
        const v=((await get(ref(njDb,k))).val()||0)+1;
        await set(ref(njDb,k),v); updChallenge('chat_msgs',v);
      };

      // ── Header injection ──
      function updateHdrStats() {
        const c=document.getElementById('nj-hb-coins'); if(c)c.textContent=`🪙 ${njCoins.toLocaleString()}`;
        const s=document.getElementById('nj-hb-streak'); if(s)s.textContent=`🔥 ${njStreak}`;
        const lv=document.getElementById('nj-hb-level'); if(lv){
          let rem=njXp,l=1; while(rem>=xpForLevel(l)){rem-=xpForLevel(l);l++;}
          const pct=Math.round(rem/xpForLevel(l-1||1)*100);
          lv.innerHTML=`⭐ Lv ${njLevel} <span style="background:#1a1a2e;border-radius:4px;width:40px;height:6px;display:inline-block;vertical-align:middle;overflow:hidden;margin:0 2px"><span style="display:block;height:100%;background:#7c3aed;width:${pct}%"></span></span>`;
        }
      }

      function buildHdrBar() {
        const bar=document.createElement('div');
        bar.id='nj-hdr-gbar';
        bar.style.cssText='display:flex;align-items:center;gap:5px;flex-shrink:0;margin-left:8px;';
        bar.innerHTML=`
          <div class="nj-stat-pill">
            <span id="nj-hb-coins" style="color:#fbbf24;font-weight:700;font-size:12px">🪙 0</span>
            <span style="color:#374151;font-size:10px">|</span>
            <span id="nj-hb-streak" style="color:#f97316;font-weight:700;font-size:12px">🔥 0</span>
            <span style="color:#374151;font-size:10px">|</span>
            <span id="nj-hb-level" style="color:#a78bfa;font-weight:700;font-size:12px">⭐ Lv 1</span>
          </div>
          <button class="nj-hdr-btn" onclick="njOpenLeaderboard()">🏆 Leaderboard</button>
          <button class="nj-hdr-btn" onclick="njOpenShop()">🛒 Shop</button>
          <button class="nj-hdr-btn" id="nj-hdr-spin-btn" onclick="njOpenSpin()" style="position:relative">🎡 Daily Spin<span id="nj-spin-dot" style="display:none;position:absolute;top:3px;right:3px;width:6px;height:6px;background:#fbbf24;border-radius:50%"></span></button>
          <button class="nj-hdr-btn" id="nj-hdr-ch-btn" onclick="njOpenChallenges()" style="position:relative">⚡ Challenges<span id="nj-ch-dot" style="display:none;position:absolute;top:3px;right:3px;width:6px;height:6px;background:#22c55e;border-radius:50%"></span></button>
          <button class="nj-hdr-btn" onclick="njOpenProfile()">👤 Profile</button>
        `;
        return bar;
      }

      function tryInjectHeader() {
        if(document.getElementById('nj-hdr-gbar'))return true;
        // Find the h1 "NJ's Unblocked Games" inside the React header
        const h1=document.querySelector('h1');
        if(!h1)return false;
        // Go up to the button element containing it, then to its parent flex row
        const titleBtn=h1.closest('button')||h1.parentElement;
        if(!titleBtn)return false;
        const headerRow=titleBtn.parentElement;
        if(!headerRow)return false;
        // Inject the gamification bar right after the title button
        const bar=buildHdrBar();
        titleBtn.insertAdjacentElement('afterend',bar);
        updateHdrStats();
        return true;
      }

      // Keep trying until React renders
      let _injectAttempts=0;
      const _injectInterval=setInterval(()=>{
        if(tryInjectHeader()||++_injectAttempts>60)clearInterval(_injectInterval);
      },200);

      // ── Leaderboard ──
      let _lbTab='pt';
      window.njLbTab=function(tab){
        _lbTab=tab;
        ['pt','xp'].forEach(t=>{
          const b=document.getElementById('nj-lb-tab-'+t); if(!b)return;
          const a=t===tab;
          b.style.background=a?'#1a1a2e':'transparent';
          b.style.color=a?'#a78bfa':'#6b7280';
          b.style.fontWeight=a?'700':'600';
          b.style.borderBottom=a?'2px solid #7c3aed':'2px solid transparent';
        });
        const note=document.getElementById('nj-lb-footer-note');
        if(note)note.textContent=tab==='xp'?'🔄 Resets every Sunday · Top 3 XP earners get coins':'🔄 Resets every Sunday · Top 3 earn coins';
        loadLeaderboard();
      };
      window.njOpenLeaderboard=function(){
        _lbTab='pt';
        document.getElementById('nj-lb-overlay').style.display='flex';
        // Reset tab visual on open
        const bpt=document.getElementById('nj-lb-tab-pt');
        if(bpt){bpt.style.background='#1a1a2e';bpt.style.color='#a78bfa';bpt.style.fontWeight='700';bpt.style.borderBottom='2px solid #7c3aed';}
        const bxp=document.getElementById('nj-lb-tab-xp');
        if(bxp){bxp.style.background='transparent';bxp.style.color='#6b7280';bxp.style.fontWeight='600';bxp.style.borderBottom='2px solid transparent';}
        loadLeaderboard();
      };
      window.njCloseLeaderboard=function(){ document.getElementById('nj-lb-overlay').style.display='none'; };
      async function loadLeaderboard(){
        const wk=weekKey();
        document.getElementById('nj-lb-week').textContent='Week '+wk;
        const listEl=document.getElementById('nj-lb-list');
        listEl.innerHTML='<div style="text-align:center;color:#6b7280;padding:20px">Loading...</div>';
        try{
          const isXp=_lbTab==='xp';
          const path=isXp?'njsgames/leaderboard/xp-weekly/'+wk:'njsgames/leaderboard/weekly/'+wk;
          const snap=await get(ref(njDb,path));
          const entries=Object.entries(snap.val()||{}).sort((a,b)=>b[1]-a[1]).slice(0,10);
          if(!entries.length){
            listEl.innerHTML='<div style="text-align:center;color:#6b7280;padding:30px">'+(isXp?'No XP data yet — play games to earn XP!':'No entries yet — start playing!')+'</div>';
            return;
          }
          const medals=['🥇','🥈','🥉'];
          const bgs=['rgba(251,191,36,.1)','rgba(156,163,175,.08)','rgba(180,120,50,.08)'];
          listEl.innerHTML=entries.map(([u,val],i)=>{
            const me=u===njUser;
            const valStr=isXp?val.toLocaleString()+' XP':fmtTime(val);
            const valColor=isXp?'#a78bfa':'#22c55e';
            return '<div class="nj-lb-row'+(me?' nj-lb-me':'')+'" '+(bgs[i]?'style="background:'+bgs[i]+'"':'')+'>'+
              '<span style="font-size:'+(i<3?'20':'13')+'px;width:28px;text-align:center;flex-shrink:0">'+(medals[i]||'#'+(i+1))+'</span>'+
              '<span style="flex:1;font-size:13px"><button onclick="njViewProfile(\''+u.replace(/'/g,"\\'")+"');njCloseLeaderboard();\" style=\"background:none;border:none;color:"+(me?'#a78bfa':'#e5e7eb')+';font-weight:'+(me?700:500)+';font-size:13px;cursor:pointer;padding:0;text-align:left">'+u+(me?' (you)':'')+'</button></span>'+
              '<span style="color:'+valColor+';font-weight:700;font-size:12px">'+valStr+'</span></div>';
          }).join('');
          const myRank=entries.findIndex(([u])=>u===njUser)+1;
          const myVal=isXp?(njXpWeekly||0).toLocaleString()+' XP this week':fmtTime(njPtWeekly);
          document.getElementById('nj-lb-my-rank').textContent=myRank>0?'Your rank: #'+myRank+' · '+myVal:njUser?'Play to appear on the board!':'';
        }catch(e){ listEl.innerHTML='<div style="text-align:center;color:#ef4444;padding:20px">Failed to load leaderboard</div>'; }
      }

      // ── Shop ──
      window.njOpenShop=function(){
        document.getElementById('nj-shop-overlay').style.display='flex';
        document.getElementById('nj-shop-balance').textContent=njCoins.toLocaleString();
        renderShop();
      };
      window.njCloseShop=function(){ document.getElementById('nj-shop-overlay').style.display='none'; };
      window.njShopTab=function(tab){
        if(tab==='lootbox'&&!_njConfig.lootboxEnabled){showToast('📦 Loot Boxes are currently disabled by the admin');return;}
        njShopTab=tab;
        document.querySelectorAll('.nj-shop-tab').forEach(b=>b.classList.remove('nj-shop-tab-active'));
        document.getElementById(`nj-shop-tab-${tab}`).classList.add('nj-shop-tab-active');
        renderShop();
      };
      function renderShop(){
        const g=document.getElementById('nj-shop-grid');
        const items=Object.entries(SHOP).filter(([,v])=>v.type===(njShopTab==='color'?'chatColor':njShopTab==='badge'?'badge':njShopTab==='title'?'title':njShopTab==='boost'?'boost':'lootbox'));
        g.innerHTML=items.map(([id,it])=>{
          const owned=!!njOwned[id], equipped=njEquipped[it.type]===id;
          let bTxt,bSt;
          if(it.type==='boost'){
            const rem=boostRemaining(it.val);
            if(rem){bTxt='⚡ Active: '+rem;bSt='background:#14532d;color:#4ade80;cursor:default';}
            else{bTxt='⚡ Activate · '+it.price+' 🪙';bSt=njCoins>=it.price?'background:#7c3aed;color:#fff':'background:#1a1a2e;color:#4b5563;cursor:not-allowed';}
          }
          else if(it.type==='lootbox'){bTxt=`Buy · ${it.price} 🪙`;bSt=njCoins>=it.price?'background:#7c3aed;color:#fff':'background:#1a1a2e;color:#4b5563;cursor:not-allowed';}
          else if(equipped){bTxt='✓ Equipped';bSt='background:#78350f;color:#fbbf24';}
          else if(owned){bTxt='Equip';bSt='background:#166534;color:#22c55e';}
          else{bTxt=`Buy · ${it.price} 🪙`;bSt=njCoins>=it.price?'background:#7c3aed;color:#fff':'background:#1a1a2e;color:#4b5563;cursor:not-allowed';}
          return `<div class="nj-shop-item${owned&&it.type!=='lootbox'?' nj-owned':''}${equipped?' nj-equipped':''}">
            <div style="font-size:28px;text-align:center">${it.icon}</div>
            <div style="color:#fff;font-weight:700;font-size:14px;text-align:center">${it.name}</div>
            <div style="color:#6b7280;font-size:11px;text-align:center;min-height:28px">${it.desc}</div>
            <button onclick="njShopAct('${id}')" style="width:100%;border:none;border-radius:8px;padding:8px;font-size:12px;font-weight:700;cursor:pointer;margin-top:4px;${bSt}">${bTxt}</button>
          </div>`;
        }).join('')||'<div style="grid-column:1/-1;text-align:center;color:#6b7280;padding:30px">Nothing here yet</div>';
      }
      let _shopBusy=false;
      window.njShopAct=async function(id){
        if(!njUser||_shopBusy)return;
        _shopBusy=true;
        try{
        const it=SHOP[id]; if(!it){_shopBusy=false;return;}
        if(it.type==='boost'){
          if(isBoostActive(it.val)){showToast('Boost already active! Wait for it to expire.');_shopBusy=false;return;}
          if(njCoins<it.price){showToast('Not enough coins 🪙');_shopBusy=false;return;}
          if(it.price>0){
            await runTransaction(ref(njDb,`njsgames/users/${njUser}/coins`),c=>(c||0)-it.price);
            njCoins-=it.price; updateHdrStats();
            document.getElementById('nj-shop-balance').textContent=njCoins.toLocaleString();
          }
          activateBoost(it.val);
          showToast(`${it.icon} ${it.name} activated!`);
          renderShop(); _shopBusy=false; return;
        }
        if(it.type==='lootbox'){
          if(!_njConfig.lootboxEnabled){showToast('📦 Loot Boxes are currently disabled');_shopBusy=false;return;}
          if(njCoins<it.price){showToast('Not enough coins 🪙');return;}
          await runTransaction(ref(njDb,`njsgames/users/${njUser}/coins`),c=>(c||0)-it.price);
          njCoins-=it.price; updateHdrStats();
          document.getElementById('nj-shop-balance').textContent=njCoins.toLocaleString();
          njPendingBox=it.val; document.getElementById('nj-lootbox-name').textContent=it.name;
          document.getElementById('nj-lootbox-pre').style.display='';
          document.getElementById('nj-lootbox-result').style.display='none';
          document.getElementById('nj-lootbox-overlay').style.display='flex';
          renderShop(); return;
        }
        const owned=!!njOwned[id], equipped=njEquipped[it.type]===id;
        if(equipped){
          await update(ref(njDb,`njsgames/users/${njUser}/equipped`),{[it.type]:null}); delete njEquipped[it.type]; showToast(`Unequipped ${it.name}`);
        } else if(owned){
          await update(ref(njDb,`njsgames/users/${njUser}/equipped`),{[it.type]:id}); njEquipped[it.type]=id; showToast(`Equipped ${it.name}!`);
        } else {
          if(njCoins<it.price){showToast('Not enough coins 🪙');return;}
          await runTransaction(ref(njDb,`njsgames/users/${njUser}/coins`),c=>(c||0)-it.price);
          njCoins-=it.price;
          await set(ref(njDb,`njsgames/users/${njUser}/items/${id}`),true); njOwned[id]=true;
          await update(ref(njDb,`njsgames/users/${njUser}/equipped`),{[it.type]:id}); njEquipped[it.type]=id;
          updateHdrStats(); document.getElementById('nj-shop-balance').textContent=njCoins.toLocaleString();
          showToast(`Bought ${it.name}!`);
        }
        renderShop();
        }catch(e){console.error('shopAct err',e);}finally{_shopBusy=false;}
      };

      // ── Loot Box ──
      window.njCloseLootBoxOverlay=function(){ document.getElementById('nj-lootbox-overlay').style.display='none'; njPendingBox=null; };
      window.njDoOpenLootBox=async function(){
        if(!njUser||!njPendingBox)return;
        const tier=njPendingBox; njPendingBox=null;
        let coins,rarity,icon,color;
        const r=Math.random();
        if(tier==='epic'){
          if(r<0.4){ const epics=Object.entries(SHOP).filter(([id,v])=>(v.type==='title'||v.type==='badge')&&v.price>=200&&!njOwned[id]); if(epics.length){ const[eid,ei]=epics[Math.floor(Math.random()*epics.length)]; await set(ref(njDb,`njsgames/users/${njUser}/items/${eid}`),true); njOwned[eid]=true; rarity='Epic';icon='🌟';color='#f59e0b'; document.getElementById('nj-lb-reward').textContent=`${ei.icon} ${ei.name} unlocked!`; } else{coins=200;} } else{coins=Math.floor(Math.random()*151)+50;}
          if(!rarity){rarity='Epic';icon='🌟';color='#f59e0b';}
        } else if(tier==='rare'){
          coins=r<0.3?75:r<0.7?50:30; rarity='Rare';icon='💜';color='#a855f7';
        } else {
          coins=[10,15,20,30][Math.floor(Math.random()*4)]; rarity='Common';icon='📦';color='#9ca3af';
        }
        if(coins){ await runTransaction(ref(njDb,`njsgames/users/${njUser}/coins`),c=>(c||0)+coins); njCoins+=coins; updateHdrStats(); document.getElementById('nj-lb-reward').textContent=`+${coins} 🪙 coins!`; }
        document.getElementById('nj-lb-icon').textContent=icon;
        document.getElementById('nj-lb-rarity').style.color=color;
        document.getElementById('nj-lb-rarity').textContent=`${rarity} Reward!`;
        document.getElementById('nj-lootbox-pre').style.display='none';
        document.getElementById('nj-lootbox-result').style.display='';
      };

      // ── Challenges ──
      window.njOpenChallenges=async function(){ document.getElementById('nj-challenges-overlay').style.display='flex'; await loadChallenges(); };
      window.njCloseChallenges=function(){ document.getElementById('nj-challenges-overlay').style.display='none'; };
      async function loadChallenges(){
        const chs=getDailyChallenges(), td=todayKey();
        const list=document.getElementById('nj-ch-list');
        let prog={};
        if(njUser){ const s=await get(ref(njDb,`njsgames/challenges/progress/${td}/${njUser}`)); prog=s.val()||{}; }
        const icons={play_minutes:'⏱️',play_games:'🎮',chat_msgs:'💬',stay_active:'🏃'};
        let all=true;
        list.innerHTML=chs.map((ch,i)=>{
          const p=prog[`c${i+1}`]||0, done=p>=ch.target, pct=Math.min(100,Math.round(p/ch.target*100));
          if(!done)all=false;
          const mult=(_njConfig.coinMult||1);
          const effReward=mult>1?Math.round(ch.reward*mult):null;
          const rewardHtml=effReward
            ?`+${ch.reward}🪙 <span style="color:#4ade80;font-size:11px;font-weight:600">(event: +${effReward}🪙)</span>`
            :`+${ch.reward}🪙`;
          return `<div style="background:#1a1a2e;border:1px solid ${done?'#22c55e':'#2a2a4a'};border-radius:12px;padding:14px">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
              <div style="display:flex;align-items:center;gap:8px"><span style="font-size:20px">${icons[ch.type]}</span><span style="color:${done?'#22c55e':'#e5e7eb'};font-weight:600;font-size:14px">${ch.label}</span></div>
              <span style="color:#fbbf24;font-weight:700;font-size:13px;white-space:nowrap;margin-left:8px">${prog[`claimed${i+1}`]?'✓ ':''} ${rewardHtml}</span>
            </div>
            <div class="nj-progress-bar"><div class="nj-progress-fill" style="width:${pct}%;background:${done?'#22c55e':'#7c3aed'}"></div></div>
            <div style="display:flex;justify-content:space-between;margin-top:5px">
              <span style="color:#6b7280;font-size:11px">${Math.min(p,ch.target)} / ${ch.target}</span>
              <span style="color:#6b7280;font-size:11px">${pct}%</span>
            </div></div>`;
        }).join('');
        const dot=document.getElementById('nj-ch-dot'); if(dot)dot.style.display=all&&!prog.bonusClaimed?'':'none';
        document.getElementById('nj-ch-bonus').innerHTML=prog.bonusClaimed
          ?'<span style="color:#22c55e">✓ All challenges complete! Bonus claimed!</span>'
          :'Complete all 3 for a <span style="color:#fbbf24">+25 🪙 bonus</span>!';
      }

      // ── Profile ──
      window.njOpenProfile=async function(){
        document.getElementById('nj-profile-overlay').style.display='flex';
        await loadProfile(null);
      };
      window.njViewProfile=async function(username){
        if(!username||username===njUser){ window.njOpenProfile(); return; }
        document.getElementById('nj-profile-overlay').style.display='flex';
        await loadProfile(username);
      };
      window.njCloseProfile=function(){ document.getElementById('nj-profile-overlay').style.display='none'; };

      async function loadProfile(targetUser){
        const isSelf = !targetUser || targetUser===njUser;
        const subject = isSelf ? njUser : targetUser;

        // Update header
        const hTitle=document.getElementById('nj-prof-header-title');
        const hSub=document.getElementById('nj-prof-header-sub');
        if(hTitle) hTitle.textContent=isSelf?'👤 Your Profile':`👤 ${subject}'s Profile`;
        if(hSub) hSub.textContent=isSelf?'':'Viewing another player';

        if(isSelf){
          // Use cached local state for own profile
          document.getElementById('nj-prof-name').textContent=njUser||'Guest';
          document.getElementById('nj-prof-level').textContent=njLevel;
          document.getElementById('nj-prof-coins').textContent=njCoins.toLocaleString();
          document.getElementById('nj-prof-streak').textContent=njStreak;
          document.getElementById('nj-prof-playtime').textContent=fmtTime(njPtTotal);
          document.getElementById('nj-prof-weekly').textContent=fmtTime(njPtWeekly);
          _renderProfileData(njUser, njEquipped, njOwned, true);
          const s=await get(ref(njDb,`njsgames/users/${njUser}/streak/longest`));
          document.getElementById('nj-prof-longest').textContent=`${s.val()||njStreak} days 🔥`;
        } else {
          // Load from Firebase for another user
          document.getElementById('nj-prof-name').textContent=subject;
          document.getElementById('nj-prof-coins').textContent='…';
          document.getElementById('nj-prof-streak').textContent='…';
          document.getElementById('nj-prof-playtime').textContent='…';
          document.getElementById('nj-prof-weekly').textContent='…';
          document.getElementById('nj-prof-longest').textContent='…';
          try{
            const snap=await get(ref(njDb,`njsgames/users/${subject}`));
            const d=snap.val()||{};
            const _ox=d.xp||0; let _ol=1,_or=_ox; while(_or>=(_ol*100)){_or-=_ol*100;_ol++;}
            document.getElementById('nj-prof-level').textContent=_ol;
            document.getElementById('nj-prof-coins').textContent=(d.coins||0).toLocaleString();
            document.getElementById('nj-prof-streak').textContent=d.streak?.current||0;
            document.getElementById('nj-prof-playtime').textContent=fmtTime(d.playtime?.total||0);
            const wk=weekKey();
            document.getElementById('nj-prof-weekly').textContent=fmtTime(d.playtime?.weekly?.[wk]||0);
            document.getElementById('nj-prof-longest').textContent=`${d.streak?.longest||0} days 🔥`;
            _renderProfileData(subject, d.equipped||{}, d.items||{}, false);
          }catch{
            document.getElementById('nj-prof-coins').textContent='N/A';
          }
        }
      }

      function _renderProfileData(username, equipped, owned, isSelf){
        const tid=equipped.title, tit=tid?SHOP[tid]:null;
        document.getElementById('nj-prof-title-display').textContent=tit?`[${tit.val}]`:'';
        const equEl=document.getElementById('nj-prof-equipped');
        const eq=Object.entries(equipped).filter(([,v])=>v).map(([,id])=>{ const it=SHOP[id]; return it?`<span style="background:#1a1a2e;border:1px solid #2a2a4a;border-radius:6px;padding:4px 8px;font-size:12px">${it.icon} ${it.name}</span>`:''; }).filter(Boolean).join('');
        equEl.innerHTML=eq||'<span style="color:#6b7280;font-size:12px">Nothing equipped</span>';
        const bdgEl=document.getElementById('nj-prof-badges');
        const lbl=document.getElementById('nj-prof-badges-label');
        if(lbl) lbl.textContent=isSelf?'My Badges':'Badges';
        const bdgs=Object.entries(owned).filter(([id,v])=>v&&SHOP[id]?.type==='badge').map(([id])=>{
          const it=SHOP[id], isEq=equipped.badge===id;
          if(isSelf){
            return `<span style="background:${isEq?'#1a1a3a':'#1a1a2e'};border:1px solid ${isEq?'#7c3aed':'#2a2a4a'};border-radius:6px;padding:4px 8px;cursor:pointer;font-size:14px" onclick="njEquipBadge('${id}')" title="Click to equip">${it.icon}</span>`;
          } else {
            return `<span style="background:${isEq?'#1a1a3a':'#1a1a2e'};border:1px solid ${isEq?'#7c3aed':'#2a2a4a'};border-radius:6px;padding:4px 8px;font-size:14px" title="${it.name}${isEq?' (equipped)':''}">${it.icon}</span>`;
          }
        }).join('');
        bdgEl.innerHTML=bdgs||(isSelf?'<span style="color:#6b7280;font-size:12px">No badges — visit Shop!</span>':'<span style="color:#6b7280;font-size:12px">No badges yet</span>');
      }

      window.njEquipBadge=async function(id){
        if(!njUser)return;
        const nid=njEquipped.badge===id?null:id;
        await update(ref(njDb,`njsgames/users/${njUser}/equipped`),{badge:nid}); njEquipped.badge=nid;
        showToast(nid?`Equipped ${SHOP[id]?.icon}!`:'Badge unequipped'); loadProfile(null);
      };

      // ── Escape key ──
      document.addEventListener('keydown',e=>{
        if(e.key==='Escape') ['nj-lb-overlay','nj-shop-overlay','nj-challenges-overlay','nj-profile-overlay','nj-lootbox-overlay','nj-jomg-overlay','nj-spin-overlay','nj-lucky-overlay','nj-ach-overlay'].forEach(id=>{ const el=document.getElementById(id); if(el)el.style.display='none'; });
      });

      // ── Init ──
      function initGam(u){
        loadUser(u);
        setupTracking();
      }

      // Expose shop items for chat
      window.njGetEquipped=()=>({...njEquipped});
      window.njShopItems=SHOP;
      window.njTrackChat=window.njTrackChat||function(){};


      // ════════════════════════════════════════════════════════
      // SITE CONFIG — loads from Firebase, drives multipliers
      // ════════════════════════════════════════════════════════
      const _njConfig = {coinMult:1, xpMult:1, spinEnabled:true, rewardsEnabled:true, chatEnabled:true, lootboxEnabled:true};
      onValue(ref(njDb,'njsgames/config'), snap=>{
        const d=snap.val()||{}, eco=d.economy||{}, feat=d.features||{};
        _njConfig.coinMult       = Math.max(1, Math.min(5, parseFloat(eco.coinMult)||1));
        _njConfig.xpMult         = Math.max(1, Math.min(5, parseFloat(eco.xpMult)||1));
        _njConfig.spinEnabled    = feat.spin_enabled    !== false;
        _njConfig.rewardsEnabled = feat.rewards_enabled !== false;
        _njConfig.chatEnabled    = feat.chat_enabled    !== false;
        _njConfig.lootboxEnabled = feat.lootbox_enabled !== false;
        // Load custom spin rewards saved by admin (persists across reloads)
        if(d.spinRewards && Array.isArray(d.spinRewards) && d.spinRewards.length){
          _spinRewards = d.spinRewards;
          if(document.getElementById('nj-spin-canvas')) _drawWheel();
        }
        // Enforce chat toggle — hide chat iframes when disabled
        document.body.classList.toggle('nj-chat-disabled', !_njConfig.chatEnabled);
        _enforceChatToggle();
        // Enforce lootbox toggle — hide the lootbox shop tab
        const _lbTabEl=document.getElementById('nj-shop-tab-lootbox');
        if(_lbTabEl)_lbTabEl.style.display=_njConfig.lootboxEnabled?'':'none';
        // Sync admin toggles if panel is open
        ['chat','spin','rewards','lootbox'].forEach(k=>{
          const el=document.getElementById('nj-ft-'+k);
          if(el) el.checked = _njConfig[k+'Enabled']!==false;
        });
        const ce=document.getElementById('nj-econ-coin');
        const xe=document.getElementById('nj-econ-xp');
        if(ce){ce.value=_njConfig.coinMult;document.getElementById('nj-econ-coin-val').textContent=_njConfig.coinMult+'×';}
        if(xe){xe.value=_njConfig.xpMult;document.getElementById('nj-econ-xp-val').textContent=_njConfig.xpMult+'×';}
        // Update site-wide banner with economy/feature events
        window._siteEvents = window._siteEvents || {};
        window._siteEvents.coinMult      = _njConfig.coinMult;
        window._siteEvents.xpMult        = _njConfig.xpMult;
        window._siteEvents.chatEnabled   = _njConfig.chatEnabled;
        window._siteEvents.rewardsEnabled= _njConfig.rewardsEnabled;
        if (window._updateSiteBanner) window._updateSiteBanner();
      });

      // ════════════════════════════════════════════════════════
      // ADMIN HELPERS
      // ════════════════════════════════════════════════════════
      // Chat enforcement helper — hides chat iframes and React chat buttons when disabled
      function _enforceChatToggle(){
        const disabled=!_njConfig.chatEnabled;
        // Hide any open chat iframes
        document.querySelectorAll('iframe[src*="chat"]').forEach(f=>{
          f.style.display=disabled?'none':'';
          if(disabled&&f.parentElement)f.parentElement.style.display='none';
        });
        // Hide React chat buttons (text match)
        document.querySelectorAll('button, a').forEach(el=>{
          const t=el.textContent.trim();
          if(t==='💬 Chat'||t==='Chat'||el.getAttribute('aria-label')==='Chat'){
            el.style.display=disabled?'none':'';
          }
        });
      }
      // Watch for dynamically added chat iframes and buttons
      const _chatEnforceObserver=new MutationObserver(()=>{
        if(!_njConfig.chatEnabled)_enforceChatToggle();
      });
      _chatEnforceObserver.observe(document.body,{childList:true,subtree:true});

      window.njToggleSection = function(bodyId, chevId){
        const b=document.getElementById(bodyId), c=document.getElementById(chevId);
        if(!b)return;
        const open=b.style.display==='none';
        b.style.display=open?'block':'none';
        if(c)c.textContent=open?'▲':'▼';
        if(open){
          if(bodyId==='nj-spin-ctrl-body')_renderSpinCtrl();
          if(bodyId==='nj-ach-ctrl-body')_renderAchCtrl();
          if(bodyId==='nj-econ-body'){
            const ce=document.getElementById('nj-econ-coin'),xe=document.getElementById('nj-econ-xp');
            if(ce){ce.value=_njConfig.coinMult;document.getElementById('nj-econ-coin-val').textContent=_njConfig.coinMult+'×';}
            if(xe){xe.value=_njConfig.xpMult;document.getElementById('nj-econ-xp-val').textContent=_njConfig.xpMult+'×';}
          }
          if(bodyId==='nj-feat-body'){
            ['chat','spin','rewards','lootbox'].forEach(k=>{
              const el=document.getElementById('nj-ft-'+k);
              if(el) el.checked = _njConfig[k+'Enabled']!==false;
            });
          }
        }
      };

      window.njSaveEconomy = async function(){
        const coin=parseFloat(document.getElementById('nj-econ-coin').value)||1;
        const xp=parseFloat(document.getElementById('nj-econ-xp').value)||1;
        await update(ref(njDb,'njsgames/config/economy'),{coinMult:coin, xpMult:xp});
        showToast(`✅ Multipliers set: coins ${coin}× · XP ${xp}×`);
      };
      window.njResetEconomy = async function(){
        await update(ref(njDb,'njsgames/config/economy'),{coinMult:1,xpMult:1});
        document.getElementById('nj-econ-coin').value=1;
        document.getElementById('nj-econ-xp').value=1;
        document.getElementById('nj-econ-coin-val').textContent='1×';
        document.getElementById('nj-econ-xp-val').textContent='1×';
        showToast('✅ Economy reset to 1×');
      };
      window.njSaveFeature = async function(key, val){
        await update(ref(njDb,'njsgames/config/features'),{[key]:val});
        showToast(`${val?'✅ Enabled':'🚫 Disabled'}: ${key.replace('_',' ')}`);
      };

      // ════════════════════════════════════════════════════════
      // SPIN WHEEL
      // ════════════════════════════════════════════════════════
      let _spinRewards = [
        {label:'50 🪙',   type:'coins', val:50,  color:'#7c3aed'},
        {label:'25 XP',   type:'xp',   val:25,  color:'#4f46e5'},
        {label:'100 🪙',  type:'coins', val:100, color:'#6d28d9'},
        {label:'50 XP',   type:'xp',   val:50,  color:'#3730a3'},
        {label:'200 🪙',  type:'coins', val:200, color:'#5b21b6'},
        {label:'75 XP',   type:'xp',   val:75,  color:'#4338ca'},
        {label:'💎 RARE', type:'rare', val:1,   color:'#d97706'},
        {label:'500 🪙',  type:'coins', val:500, color:'#b45309'},
      ];
      let _spinAngle=0, _spinning=false;

      function _drawWheel(){
        const c=document.getElementById('nj-spin-canvas');
        if(!c)return;
        const ctx=c.getContext('2d'), n=_spinRewards.length, r=c.width/2, cx=r, cy=r, arc=2*Math.PI/n;
        ctx.clearRect(0,0,c.width,c.height);
        for(let i=0;i<n;i++){
          const start=_spinAngle+i*arc, end=start+arc;
          ctx.beginPath(); ctx.moveTo(cx,cy); ctx.arc(cx,cy,r-2,start,end); ctx.closePath();
          ctx.fillStyle=_spinRewards[i].color; ctx.fill();
          ctx.strokeStyle='#0a0a15'; ctx.lineWidth=2; ctx.stroke();
          // Label
          ctx.save(); ctx.translate(cx,cy); ctx.rotate(start+arc/2);
          ctx.textAlign='right'; ctx.fillStyle='#fff'; ctx.font='bold 12px Inter,sans-serif';
          ctx.shadowColor='rgba(0,0,0,0.8)'; ctx.shadowBlur=3;
          ctx.fillText(_spinRewards[i].label, r-10, 5);
          ctx.restore();
        }
        // Center circle
        ctx.beginPath(); ctx.arc(cx,cy,18,0,2*Math.PI);
        ctx.fillStyle='#0a0a15'; ctx.fill();
        ctx.strokeStyle='#7c3aed'; ctx.lineWidth=3; ctx.stroke();
      }

      function _updateSpinTimer(){
        const btn=document.getElementById('nj-spin-btn');
        const timerEl=document.getElementById('nj-spin-timer');
        if(!btn||!timerEl)return;
        const last=parseInt(localStorage.getItem('nj_spin_last')||'0');
        const now=Date.now(), cooldown=24*60*60*1000;
        const remain=last+cooldown-now;
        if(remain<=0){
          btn.disabled=false; btn.textContent='🎯 SPIN!';
          timerEl.textContent='';
        } else {
          btn.disabled=true;
          const h=Math.floor(remain/3600000),m=Math.floor((remain%3600000)/60000),s=Math.floor((remain%60000)/1000);
          btn.textContent='⏳ Come back in '+h+'h '+m+'m';
          timerEl.textContent='Next spin in '+h+'h '+m+'m '+s+'s';
        }
      }

      window.njOpenSpin = function(){
        if(!_njConfig.spinEnabled){showToast('🎡 Spin Wheel is currently disabled');return;}
        // Reset reveal state from any previous spin
        const reveal=document.getElementById('nj-spin-reward-reveal');
        if(reveal){reveal.style.display='none';reveal.innerHTML='';}
        const spinBtnEl=document.getElementById('nj-spin-btn');
        const timerEl2=document.getElementById('nj-spin-timer');
        if(spinBtnEl)spinBtnEl.style.display='';
        if(timerEl2)timerEl2.style.display='';
        document.getElementById('nj-spin-overlay').style.display='flex';
        _drawWheel(); _updateSpinTimer();
        clearInterval(window._spinTimerInt);
        window._spinTimerInt=setInterval(_updateSpinTimer,1000);
      };

      window.njDoSpin = function(){
        if(_spinning)return;
        const last=parseInt(localStorage.getItem('nj_spin_last')||'0');
        if(Date.now()-last < 24*60*60*1000){showToast('⏳ Already spun today!');return;}
        _spinning=true;
        document.getElementById('nj-spin-btn').disabled=true;
        const n=_spinRewards.length, arc=2*Math.PI/n;
        const winner=Math.floor(Math.random()*n);
        // Spin to land pointer (top) on winner segment
        const targetAngle=2*Math.PI*5 + (Math.PI*1.5 - (winner*arc+arc/2) - _spinAngle);
        const start=_spinAngle, total=targetAngle;
        const duration=4000, startTime=performance.now();
        function anim(t){
          const elapsed=t-startTime, p=Math.min(elapsed/duration,1);
          const ease=1-Math.pow(1-p,4);
          _spinAngle=start+total*ease;
          _drawWheel();
          if(p<1){requestAnimationFrame(anim);}
          else{
            _spinAngle=start+total;
            _drawWheel();
            _spinning=false;
            localStorage.setItem('nj_spin_last',Date.now().toString());
            _updateSpinTimer();
            setTimeout(()=>_giveSpinReward(_spinRewards[winner]),400);
          }
        }
        requestAnimationFrame(anim);
      };

      async function _giveSpinReward(r){
        let rewardMsg='', rewardIcon='🎁';
        if(r.type==='coins'){
          await awardCoins(r.val,'🎡 Spin');
          rewardIcon='🪙'; rewardMsg='+'+r.val+' Coins!';
        } else if(r.type==='xp'){
          await awardXp(r.val);
          rewardIcon='⭐'; rewardMsg='+'+r.val+' XP!';
        } else if(r.type==='rare'){
          const notOwned=Object.entries(SHOP).filter(([id,it])=>it.type==='badge'&&!njOwned[id]);
          if(notOwned.length){
            const [id,it]=notOwned[Math.floor(Math.random()*notOwned.length)];
            await set(ref(njDb,`njsgames/users/${njUser}/items/${id}`),true);
            njOwned[id]=true;
            rewardIcon=it.icon||'💎'; rewardMsg='Rare Item: '+it.name+'!';
          } else {
            await awardCoins(750,'💎 Rare spin');
            rewardIcon='💎'; rewardMsg='+750 Coins (Rare)!';
          }
        }
        _checkAchievements({spinUsed:true});
        // Show reward card with Collect button
        const reveal=document.getElementById('nj-spin-reward-reveal');
        if(reveal){
          reveal.innerHTML=`
            <div style="margin-top:18px;background:#0a0a15;border:2px solid #7c3aed;border-radius:16px;padding:18px 16px;text-align:center;animation:nj-ach-slide 0.35s ease">
              <div style="color:#a78bfa;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px">🎉 You Won!</div>
              <div style="font-size:36px;margin-bottom:4px">${rewardIcon}</div>
              <div style="color:#fff;font-size:18px;font-weight:800;margin-bottom:16px">${rewardMsg}</div>
              <button onclick="document.getElementById('nj-spin-overlay').style.display='none'" style="width:100%;background:linear-gradient(135deg,#22c55e,#16a34a);border:none;border-radius:12px;color:#fff;font-size:15px;font-weight:800;padding:13px 0;cursor:pointer;box-shadow:0 4px 18px rgba(34,197,94,0.35)">✅ Collect &amp; Go Back</button>
            </div>`;
          reveal.style.display='block';
          // hide the spin button area so only Collect is shown
          const btn=document.getElementById('nj-spin-btn');
          const timer=document.getElementById('nj-spin-timer');
          if(btn)btn.style.display='none';
          if(timer)timer.style.display='none';
        }
      }

      // Admin spin control
      function _renderSpinCtrl(){
        const el=document.getElementById('nj-spin-rewards-edit');
        if(!el)return;
        el.innerHTML=_spinRewards.map((r,i)=>`
          <div style="display:flex;align-items:center;gap:6px">
            <input value="${r.label}" id="nj-sr-lbl-${i}" style="flex:1;background:#0a0a15;border:1px solid #2a2a4a;border-radius:6px;color:#fff;padding:5px 8px;font-size:11px">
            <select id="nj-sr-type-${i}" style="background:#0a0a15;border:1px solid #2a2a4a;border-radius:6px;color:#9ca3af;padding:5px">
              <option value="coins" ${r.type==='coins'?'selected':''}>🪙 Coins</option>
              <option value="xp"    ${r.type==='xp'?'selected':''}>⭐ XP</option>
              <option value="rare"  ${r.type==='rare'?'selected':''}>💎 Rare</option>
            </select>
            <input type="number" value="${r.val}" id="nj-sr-val-${i}" style="width:60px;background:#0a0a15;border:1px solid #2a2a4a;border-radius:6px;color:#fff;padding:5px;font-size:11px">
            <input type="color" value="${r.color}" id="nj-sr-col-${i}" style="width:32px;height:32px;border:none;border-radius:6px;cursor:pointer;background:none;padding:0">
          </div>`).join('');
      }
      window.njSaveSpinRewards=function(){
        _spinRewards=_spinRewards.map((_,i)=>({
          label:document.getElementById('nj-sr-lbl-'+i).value,
          type:document.getElementById('nj-sr-type-'+i).value,
          val:parseInt(document.getElementById('nj-sr-val-'+i).value)||0,
          color:document.getElementById('nj-sr-col-'+i).value,
        }));
        // Persist to Firebase so rewards survive page reloads
        set(ref(njDb,'njsgames/config/spinRewards'),_spinRewards);
        _drawWheel(); showToast('✅ Spin rewards saved!');
      };
      window.njResetSpinRewards=function(){
        _spinRewards=[
          {label:'50 🪙',type:'coins',val:50,color:'#7c3aed'},{label:'25 XP',type:'xp',val:25,color:'#4f46e5'},
          {label:'100 🪙',type:'coins',val:100,color:'#6d28d9'},{label:'50 XP',type:'xp',val:50,color:'#3730a3'},
          {label:'200 🪙',type:'coins',val:200,color:'#5b21b6'},{label:'75 XP',type:'xp',val:75,color:'#4338ca'},
          {label:'💎 RARE',type:'rare',val:1,color:'#d97706'},{label:'500 🪙',type:'coins',val:500,color:'#b45309'},
        ];
        // Clear custom rewards from Firebase so defaults are used on next load
        set(ref(njDb,'njsgames/config/spinRewards'),null);
        _renderSpinCtrl(); _drawWheel(); showToast('✅ Rewards reset');
      };

      // ════════════════════════════════════════════════════════
      // ACHIEVEMENT SYSTEM
      // ════════════════════════════════════════════════════════
      const ACHIEVEMENTS = [
        {id:'first_play',    icon:'🎮', name:'First Steps',      desc:'Play your first game',           req:{plays:1},   reward:{type:'coins',val:25}},
        {id:'plays_5',       icon:'🕹️', name:'Getting Warmed Up', desc:'Play 5 different games',         req:{plays:5},   reward:{type:'coins',val:75}},
        {id:'plays_25',      icon:'🔥', name:'Dedicated Gamer',   desc:'Play 25 games',                  req:{plays:25},  reward:{type:'coins',val:200}},
        {id:'coins_100',     icon:'💰', name:'Coin Hoarder',      desc:'Earn 100 coins total',           req:{coins:100}, reward:{type:'xp',val:50}},
        {id:'coins_1000',    icon:'🤑', name:'Rolling in It',     desc:'Earn 1,000 coins total',         req:{coins:1e3}, reward:{type:'coins',val:250}},
        {id:'level_5',       icon:'⭐', name:'Rising Star',       desc:'Reach Level 5',                  req:{level:5},   reward:{type:'coins',val:150}},
        {id:'streak_7',      icon:'📅', name:'Week Warrior',      desc:'7-day login streak',             req:{streak:7},  reward:{type:'coins',val:300}},
        {id:'spin_first',    icon:'🎡', name:'Wheel of Fortune',  desc:'Use the daily spin wheel',       req:{spins:1},   reward:{type:'xp',val:75}},
        {id:'spin_7',        icon:'🌀', name:'Spin Master',       desc:'Spin the wheel 7 times',         req:{spins:7},   reward:{type:'coins',val:200}},
        {id:'lucky_drop',    icon:'🍀', name:'Lucky Charm',       desc:'Claim a lucky reward drop',      req:{lucky:1},   reward:{type:'xp',val:100}},
        {id:'shop_buy',      icon:'🏪', name:'Shopaholic',        desc:'Buy something from the shop',    req:{buys:1},    reward:{type:'coins',val:50}},
        {id:'chat_10',       icon:'💬', name:'Chatterbox',        desc:'Send 10 chat messages',          req:{chats:10},  reward:{type:'coins',val:75}},
      ];

      let _achStats = {};   // loaded from localStorage
      let _achDone  = {};   // granted achievements

      function _loadAchStats(){
        try{ _achStats=JSON.parse(localStorage.getItem('nj_ach_stats')||'{}'); }catch{_achStats={};}
        try{ _achDone=JSON.parse(localStorage.getItem('nj_ach_done')||'{}'); }catch{_achDone={};}
        // Sync from Firebase
        if(njUser) get(ref(njDb,`njsgames/users/${njUser}/achievements`)).then(s=>{
          if(s.val()) Object.assign(_achDone, s.val());
          localStorage.setItem('nj_ach_done', JSON.stringify(_achDone));
        });
      }

      function _saveAchStats(){
        localStorage.setItem('nj_ach_stats', JSON.stringify(_achStats));
      }

      function _showAchUnlocked(ach){
        document.getElementById('nj-ach-icon').textContent=ach.icon;
        document.getElementById('nj-ach-name').textContent=ach.name;
        const rv=ach.reward;
        document.getElementById('nj-ach-reward').textContent=(rv.type==='coins'?'+'+rv.val+' 🪙':'+'+rv.val+' XP ✨')+' Reward!';
        const ov=document.getElementById('nj-ach-overlay');
        ov.style.display='block';
        clearTimeout(window._achTimer);
        window._achTimer=setTimeout(()=>ov.style.display='none',4500);
      }

      async function _unlockAch(ach){
        if(_achDone[ach.id])return;
        _achDone[ach.id]=Date.now();
        localStorage.setItem('nj_ach_done',JSON.stringify(_achDone));
        if(njUser) await update(ref(njDb,`njsgames/users/${njUser}/achievements`),{[ach.id]:Date.now()});
        _showAchUnlocked(ach);
        if(ach.reward.type==='coins') await awardCoins(ach.reward.val,'🏆 Achievement');
        else await awardXp(ach.reward.val,true);
      }

      function _checkAchievements(event={}){
        if(!njUser)return;
        // Update stats
        if(event.gamePlayed){ _achStats.plays=(_achStats.plays||0)+1; _saveAchStats(); }
        if(event.coinEarned){ _achStats.coinsEarned=(_achStats.coinsEarned||0)+event.coinEarned; _saveAchStats(); }
        if(event.spinUsed){ _achStats.spins=(_achStats.spins||0)+1; _saveAchStats(); }
        if(event.luckyDrop){ _achStats.lucky=(_achStats.lucky||0)+1; _saveAchStats(); }
        if(event.shopBuy){ _achStats.buys=(_achStats.buys||0)+1; _saveAchStats(); }
        if(event.chatMsg){ _achStats.chats=(_achStats.chats||0)+1; _saveAchStats(); }

        // Check conditions
        const s=_achStats;
        ACHIEVEMENTS.forEach(a=>{
          if(_achDone[a.id])return;
          const r=a.req;
          if(r.plays    && (s.plays||0)      >= r.plays)    _unlockAch(a);
          if(r.coins    && (s.coinsEarned||0) >= r.coins)   _unlockAch(a);
          if(r.level    && njLevel            >= r.level)    _unlockAch(a);
          if(r.streak   && njStreak           >= r.streak)   _unlockAch(a);
          if(r.spins    && (s.spins||0)       >= r.spins)    _unlockAch(a);
          if(r.lucky    && (s.lucky||0)       >= r.lucky)    _unlockAch(a);
          if(r.buys     && (s.buys||0)        >= r.buys)     _unlockAch(a);
          if(r.chats    && (s.chats||0)       >= r.chats)    _unlockAch(a);
        });
      }

      // Admin achievement control
      function _renderAchCtrl(){
        const el=document.getElementById('nj-ach-ctrl-list');
        if(!el)return;
        el.innerHTML=ACHIEVEMENTS.map(a=>`
          <div style="display:flex;align-items:center;justify-content:space-between;background:#0a0a15;border:1px solid ${_achDone[a.id]?'#22c55e':'#1a1a2e'};border-radius:8px;padding:8px 10px">
            <div style="display:flex;align-items:center;gap:8px">
              <span style="font-size:18px">${a.icon}</span>
              <div>
                <div style="color:#fff;font-size:12px;font-weight:600">${a.name}</div>
                <div style="color:#6b7280;font-size:11px">${a.desc}</div>
              </div>
            </div>
            <div style="text-align:right">
              <div style="color:${a.reward.type==='coins'?'#fbbf24':'#a78bfa'};font-size:11px">${a.reward.type==='coins'?'+'+a.reward.val+' 🪙':'+'+a.reward.val+' XP'}</div>
              <div style="color:${_achDone[a.id]?'#22c55e':'#374151'};font-size:10px">${_achDone[a.id]?'✓ Done':'Locked'}</div>
            </div>
          </div>`).join('');
      }

      // ════════════════════════════════════════════════════════
      // LUCKY DROP — random reward after playing
      // ════════════════════════════════════════════════════════
      let _luckyPending = null;
      function _tryLuckyDrop(){
        if(!njUser||!_njConfig.rewardsEnabled)return;
        if(Math.random()>0.20)return;  // 20% chance
        const rewards=[
          {msg:'+50 🪙 Lucky find!',   type:'coins',val:50},
          {msg:'+100 🪙 Great drop!',  type:'coins',val:100},
          {msg:'+30 XP Lucky bonus!',  type:'xp',   val:30},
          {msg:'+75 XP Jackpot XP!',   type:'xp',   val:75},
          {msg:'+150 🪙 Big drop!',    type:'coins',val:150},
        ];
        _luckyPending=rewards[Math.floor(Math.random()*rewards.length)];
        document.getElementById('nj-lucky-msg').textContent=_luckyPending.msg;
        document.getElementById('nj-lucky-overlay').style.display='block';
        clearTimeout(window._luckyTimer);
        window._luckyTimer=setTimeout(()=>{
          document.getElementById('nj-lucky-overlay').style.display='none';
          _luckyPending=null;
        }, 12000);
      }

      window.njClaimLucky = async function(){
        if(!_luckyPending)return;
        document.getElementById('nj-lucky-overlay').style.display='none';
        const r=_luckyPending; _luckyPending=null;
        clearTimeout(window._luckyTimer);
        if(r.type==='coins') await awardCoins(r.val,'🍀 Lucky Drop');
        else await awardXp(r.val);
        _checkAchievements({luckyDrop:true});
      };

      // ════════════════════════════════════════════════════════
      // RECENTLY PLAYED tracking
      // ════════════════════════════════════════════════════════
      const _MAX_RECENT=8;
      function trackRecentGame(gameId){
        let recent=[];
        try{recent=JSON.parse(localStorage.getItem('nj_recent')||'[]');}catch{}
        recent=recent.filter(id=>id!==gameId);
        recent.unshift(gameId);
        if(recent.length>_MAX_RECENT)recent=recent.slice(0,_MAX_RECENT);
        localStorage.setItem('nj_recent',JSON.stringify(recent));
        _checkAchievements({gamePlayed:true});
      }
      window.njGetRecent=function(){
        try{return JSON.parse(localStorage.getItem('nj_recent')||'[]');}catch{return[];}
      };

      // ════════════════════════════════════════════════════════
      // HOOK: game play tracking → achievements + lucky drop
      // ════════════════════════════════════════════════════════
      (function(){
        const orig=window.updatePresenceGame||function(){};
        let _lastGameId=null, _gameStartTime=0;
        window.updatePresenceGame=function(gid){
          if(gid && gid!==_lastGameId){
            if(_lastGameId && _gameStartTime && (Date.now()-_gameStartTime)>=180000){
              _tryLuckyDrop();
            }
            trackRecentGame(gid);
            _lastGameId=gid;
            _gameStartTime=Date.now();
          } else if(!gid && _lastGameId){
            if(_gameStartTime && (Date.now()-_gameStartTime)>=180000){
              _tryLuckyDrop();
            }
            _lastGameId=null;
          }
          return orig(gid);
        };
      })();

      // ════════════════════════════════════════════════════════
      // HOOK: shop buy → achievement
      // ════════════════════════════════════════════════════════
      (function(){
        const orig=window.njShopAct;
        if(orig) window.njShopAct=async function(id){
          await orig(id);
          const it=SHOP[id];
          if(it&&it.type!=='boost'&&it.type!=='lootbox'&&njOwned[id]){
            _checkAchievements({shopBuy:true});
          }
        };
      })();

      // ════════════════════════════════════════════════════════
      // INIT: load ach stats when user loads
      // ════════════════════════════════════════════════════════
      (function(){
        const origLoad=window.initGam;
        window.initGam=function(u){
          if(origLoad)origLoad(u);
          setTimeout(()=>{
            _loadAchStats();
            _checkAchievements({});
          },1500);
        };
      })();

      // ── Expose spin button globally (called from header) ──
      window.njOpenSpinWheel=window.njOpenSpin;

      // ── Spin dot indicator — show yellow badge when spin is available ──
      function _updateSpinDot(){
        const dot=document.getElementById('nj-spin-dot');
        if(!dot)return;
        const last=parseInt(localStorage.getItem('nj_spin_last')||'0');
        dot.style.display=(Date.now()-last>=24*60*60*1000)?'block':'none';
      }
      setInterval(_updateSpinDot, 30000);
      setTimeout(_updateSpinDot, 2000);


      // Wait for username from main system
      let _wait=0;
      const _wi=setInterval(()=>{
        if(window._njUsername){ clearInterval(_wi); initGam(window._njUsername); }
        else if(++_wait>120) clearInterval(_wi);
      },500);

    </script>

  
    <!-- Daily Spin Wheel -->
    <div id="nj-spin-overlay">
      <div id="nj-spin-modal">
        <button onclick="document.getElementById('nj-spin-overlay').style.display='none'" style="position:absolute;top:14px;right:18px;background:none;border:none;color:#6b7280;font-size:20px;cursor:pointer">✕</button>
        <div style="font-size:28px;margin-bottom:4px">🎡</div>
        <h3 style="color:#fff;margin:0 0 16px;font-size:18px;font-weight:800">Daily Spin!</h3>
        <div id="nj-wheel-wrap">
          <div id="nj-wheel-ptr">▼</div>
          <canvas id="nj-spin-canvas" width="280" height="280"></canvas>
        </div>
        <button id="nj-spin-btn" onclick="njDoSpin()">🎯 SPIN!</button>
        <div id="nj-spin-timer"></div>
        <div id="nj-spin-reward-reveal" style="display:none"></div>
      </div>
    </div>

    <!-- Lucky Drop -->
    <div id="nj-lucky-overlay">
      <div id="nj-lucky-box">
        <div style="font-size:36px;margin-bottom:8px">🎁</div>
        <div style="color:#fbbf24;font-weight:800;font-size:16px;margin-bottom:4px">Lucky Drop!</div>
        <div id="nj-lucky-msg" style="color:#e5e7eb;font-size:14px;margin-bottom:14px">+50 🪙</div>
        <button onclick="njClaimLucky()" style="background:linear-gradient(135deg,#f59e0b,#d97706);border:none;border-radius:10px;color:#fff;font-weight:800;font-size:14px;padding:10px 28px;cursor:pointer">✨ Claim!</button>
      </div>
    </div>

    <!-- Achievement Unlocked -->
    <div id="nj-ach-overlay">
      <div id="nj-ach-box">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
          <span style="font-size:26px" id="nj-ach-icon">🏆</span>
          <div>
            <div style="color:#4ade80;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase">Achievement Unlocked!</div>
            <div style="color:#fff;font-weight:800;font-size:14px" id="nj-ach-name">First Steps</div>
          </div>
        </div>
        <div style="color:#86efac;font-size:12px" id="nj-ach-reward">+50 🪙</div>
      </div>
    </div>

    <!-- Level-Up Notification -->
    <div id="nj-levelup-overlay" style="display:none;position:fixed;top:80px;left:50%;transform:translateX(-50%);z-index:10020;pointer-events:none;animation:nj-levelup-pop 3.5s ease-out forwards;">
      <div style="background:linear-gradient(135deg,#7c3aed,#4f46e5);border:2px solid #a78bfa;border-radius:20px;padding:20px 36px;text-align:center;box-shadow:0 0 40px rgba(124,58,237,0.7);">
        <div style="font-size:32px;margin-bottom:4px">⭐</div>
        <div style="color:#fff;font-size:13px;font-weight:600;opacity:0.8">LEVEL UP!</div>
        <div style="color:#fff;font-size:28px;font-weight:900">Level <span id="nj-levelup-num">2</span></div>
        <div style="color:#c4b5fd;font-size:11px;margin-top:4px">Keep playing to level up more!</div>
      </div>
    </div>

    <!-- Just One More Game Overlay -->
    <div id="nj-jomg-overlay" style="display:none;position:fixed;bottom:24px;right:24px;z-index:10015;max-width:320px;">
      <div style="background:linear-gradient(135deg,#0f0f1a,#1a1a2e);border:2px solid #7c3aed;border-radius:20px;padding:22px;box-shadow:0 8px 40px rgba(124,58,237,0.5);">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px;">
          <div>
            <div style="font-size:22px">🎮</div>
            <div style="color:#fff;font-weight:800;font-size:16px;margin-top:4px">Just One More?</div>
          </div>
          <button onclick="njJomgClose()" style="background:none;border:none;color:#6b7280;cursor:pointer;font-size:18px;line-height:1;padding:2px">✕</button>
        </div>
        <div style="color:#9ca3af;font-size:13px;line-height:1.5;margin-bottom:16px">Play another game and earn a <span style="color:#a78bfa;font-weight:700">+20 XP bonus</span>! Don't break your momentum! 🔥</div>
        <div style="display:flex;gap:8px;">
          <button onclick="njJomgPlay()" style="flex:1;background:linear-gradient(135deg,#7c3aed,#4f46e5);border:none;border-radius:10px;color:#fff;font-weight:700;font-size:13px;padding:10px 14px;cursor:pointer">🎮 Play Another!</button>
          <button onclick="njJomgClose()" style="background:#1a1a2e;border:1px solid #2a2a4a;border-radius:10px;color:#6b7280;font-size:12px;padding:10px 12px;cursor:pointer">Later</button>
        </div>
        <div style="margin-top:12px;background:#0a0a15;border-radius:8px;padding:10px;text-align:center;">
          <div style="color:#6b7280;font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px">📢 Ad Space · Coming Soon</div>
          <div style="color:#4b5563;font-size:11px">Support NJ's Unblocked Games!</div>
        </div>
      </div>
    </div>


    <style>
      .nj-admin-section-hdr{display:flex;align-items:center;padding:10px 14px;cursor:pointer;background:#0a0a15;border-top:1px solid #1a1a2e;font-size:13px;font-weight:600;color:#e5e7eb;user-select:none;}
      .nj-admin-section-hdr:hover{background:#0f0f1a;}
      .nj-toggle-row{display:flex;align-items:center;justify-content:space-between;background:#0a0a15;border:1px solid #1a1a2e;border-radius:7px;padding:8px 10px;font-size:12px;color:#9ca3af;cursor:pointer;}
      .nj-toggle-row input[type=checkbox]{width:16px;height:16px;cursor:pointer;accent-color:#7c3aed;}
      /* Spin Wheel */
      #nj-spin-overlay{display:none;position:fixed;inset:0;z-index:10030;background:rgba(0,0,0,0.85);align-items:center;justify-content:center;backdrop-filter:blur(4px);}
      #nj-spin-modal{background:linear-gradient(135deg,#0f0f1a,#1a1a2e);border:2px solid #7c3aed;border-radius:24px;padding:28px 24px;max-width:380px;width:90%;text-align:center;box-shadow:0 0 60px rgba(124,58,237,0.4);}
      #nj-wheel-wrap{position:relative;width:280px;height:280px;margin:0 auto 18px;}
      #nj-wheel-ptr{position:absolute;top:-14px;left:50%;transform:translateX(-50%);font-size:24px;z-index:2;filter:drop-shadow(0 2px 4px #000);}
      #nj-spin-canvas{border-radius:50%;box-shadow:0 0 30px rgba(124,58,237,0.5);}
      #nj-spin-btn{background:linear-gradient(135deg,#7c3aed,#4f46e5);border:none;border-radius:12px;color:#fff;font-size:16px;font-weight:800;padding:14px 40px;cursor:pointer;transition:all 0.2s;letter-spacing:0.5px;}
      #nj-spin-btn:hover{transform:scale(1.04);}
      #nj-spin-btn:disabled{background:#374151;color:#6b7280;cursor:not-allowed;transform:none;}
      #nj-spin-timer{color:#6b7280;font-size:12px;margin-top:10px;min-height:18px;}
      /* Lucky Drop */
      #nj-lucky-overlay{display:none;position:fixed;bottom:90px;right:24px;z-index:10025;max-width:300px;animation:nj-lucky-pop 0.4s cubic-bezier(0.175,0.885,0.32,1.275);}
      @keyframes nj-lucky-pop{from{opacity:0;transform:scale(0.6) translateY(20px);}to{opacity:1;transform:scale(1) translateY(0);}}
      #nj-lucky-box{background:linear-gradient(135deg,#0f0f1a,#1a1a2e);border:2px solid #fbbf24;border-radius:18px;padding:20px;box-shadow:0 8px 40px rgba(251,191,36,0.3);text-align:center;}
      /* Achievement */
      #nj-ach-overlay{display:none;position:fixed;top:80px;right:20px;z-index:10028;max-width:280px;animation:nj-ach-slide 0.4s ease;}
      @keyframes nj-ach-slide{from{opacity:0;transform:translateX(60px);}to{opacity:1;transform:translateX(0);}}
      #nj-ach-box{background:linear-gradient(135deg,#0f2a10,#1a3a1a);border:2px solid #22c55e;border-radius:16px;padding:16px;box-shadow:0 8px 30px rgba(34,197,94,0.3);}
      /* Event indicator pulse dot */
      @keyframes nj-event-pulse{0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,0.7);}70%{box-shadow:0 0 0 6px rgba(34,197,94,0);}}
      #nj-event-pulse-dot{animation:nj-event-pulse 1.5s infinite;}
    </style>

    <style>
      @keyframes nj-levelup-pop {
        0%{opacity:0;transform:translateX(-50%) scale(0.7);}
        15%{opacity:1;transform:translateX(-50%) scale(1.05);}
        25%{transform:translateX(-50%) scale(1);}
        75%{opacity:1;transform:translateX(-50%) scale(1);}
        100%{opacity:0;transform:translateX(-50%) scale(0.9);}
      }
    </style>

</body>
</html>